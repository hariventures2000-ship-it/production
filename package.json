{
  "name": "hariventure-digital-production",
  "version": "1.0.0",
  "private": true,
  "description": "Hariventure Digital Production — Enterprise SaaS Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@jest/core": "^30.4.2",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.17.6",
    "exit": "^0.1.2",
    "mongodb-connection-string-url": "^7.0.1",
    "object-hash": "^3.0.0",
    "path-scurry": "^2.0.2",
    "pkg-dir": "^8.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "y18n": "^5.0.8"
  },
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@nestjs/schedule": "^6.1.3",
    "@tanstack/query-devtools": "^5.101.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "pdfkit": "^0.19.1",
    "razorpay": "^2.9.6"
  }
}