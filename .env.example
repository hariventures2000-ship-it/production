# ═══════════════════════════════════════════════════════════════
# HARIVENTURE DIGITAL PRODUCTION — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ─── APPLICATION ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── MONGODB ATLAS ──────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=

# ─── JWT SECRETS ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_EMAIL_VERIFY_SECRET=
JWT_PASSWORD_RESET_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_EMAIL_VERIFY_EXPIRES_IN=24h
JWT_PASSWORD_RESET_EXPIRES_IN=1h

# ─── MFA (TOTP — Microsoft Authenticator) ───────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# MUST be exactly 32 characters for AES-256
MFA_ENCRYPTION_KEY=
MFA_ISSUER=Hariventure

# ─── REDIS (Upstash recommended for production) ──────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ─── OTP SETTINGS ────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# ─── CLOUDINARY ──────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── RESEND (Email) ───────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@hariventure.com
RESEND_FROM_NAME=Hariventure Digital Production

# ─── OLLAMA (AI) ──────────────────────────────────────────────────
# Local development: http://localhost:11434
# Production: VPS Ollama instance URL
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_SUMMARY=llama3.1
OLLAMA_MODEL_ANALYSIS=qwen3
OLLAMA_TIMEOUT_MS=60000

# ─── RATE LIMITING ────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL=60000
AUTH_THROTTLE_LIMIT=5

# ─── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://hariventure.com

# ─── SWAGGER ──────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# ─── NEXT.JS (Frontend) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Hariventure Digital Production
NEXT_PUBLIC_APP_URL=http://localhost:3000
